OPENCLAW_IMAGE=openclaw:latest
OPENCLAW_GATEWAY_TOKEN=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_PORT=18789

OPENCLAW_CONFIG_DIR=/home/openclaw/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/openclaw/.openclaw/workspace
OPENCLAW_TZ=UTC
OPENCLAW_HANDSHAKE_TIMEOUT_MS=10000

GOG_KEYRING_PASSWORD=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32
XDG_CONFIG_HOME=/home/node/.openclaw

# AI provider API key (stored in ~/.openclaw/.env, not here)
# Set ONE of the following depending on your chosen provider:
#   ANTHROPIC_API_KEY=sk-ant-...
#   MINIMAX_API_KEY=...
#   ZHIPU_API_KEY=...
#   OPENAI_API_KEY=...  (for any OpenAI-compatible provider)

# Simulates a fresh Ubuntu VPS for testing setup.sh
# Uses systemd-enabled image so services (sshd, fail2ban, etc.) work correctly.
#
# Usage:
#   docker build -f test/Dockerfile.test -t openclaw-test .
#   docker run --rm --privileged -v /sys/fs/cgroup:/sys/fs/cgroup:rw openclaw-test
#
# The container runs test/test-setup.sh which exercises setup.sh in a
# non-interactive mode and validates each step completed correctly.

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV container=docker

# Install systemd and basic init requirements
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends systemd systemd-sysv dbus openssh-server sudo && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* && \
    # Remove unnecessary systemd units that break in containers
    rm -f /lib/systemd/system/multi-user.target.wants/* \
          /etc/systemd/system/*.wants/* \
          /lib/systemd/system/local-fs.target.wants/* \
          /lib/systemd/system/sockets.target.wants/*udev* \
          /lib/systemd/system/sockets.target.wants/*initctl* \
          /lib/systemd/system/sysinit.target.wants/systemd-tmpfiles-setup* \
          /lib/systemd/system/systemd-update-utmp*

# Ensure sshd host keys exist (setup.sh restarts sshd)
RUN ssh-keygen -A

# Copy the boilerplate repo into the container
COPY . /opt/openclaw-boilerplate

# Generate a test SSH key for non-interactive setup
RUN ssh-keygen -t ed25519 -f /root/.ssh/id_test -N "" -q && \
    mkdir -p /root/.ssh && \
    cp /root/.ssh/id_test.pub /root/.ssh/authorized_keys && \
    chmod 700 /root/.ssh && \
    chmod 600 /root/.ssh/authorized_keys

WORKDIR /opt/openclaw-boilerplate

USER root

STOPSIGNAL SIGRTMIN+3
CMD ["/bin/bash", "-c", "/opt/openclaw-boilerplate/test/test-setup.sh"]
